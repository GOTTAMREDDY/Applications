pipeline {
    agent any

    environment {
        // AWS_REGION = "us-east-1"
        // ACCOUNT_ID = "123456789012"
        HUB_REPO = 'MongoDb'
        IMAGE_TAG = "${BUILD_NUMBER}"
    // ECR_URI = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${HUB_REPO}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/GOTTAMREDDY/Applications.git'
            }
        }
    }
    stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'Docker_details',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${HUB_REPO}:${IMAGE_TAG} .
                docker tag ${HUB_REPO}:${IMAGE_TAG} sadashivareddy/${HUB_REPO}:${IMAGE_TAG}

                docker push sadashivareddy/${HUB_REPO}:${IMAGE_TAG}
                """
            }
        }
    }
    post {
        success {
            echo 'Deployment Successful!'
        }
        failure {
            echo 'Pipeline Failed!'
        }
    }
}
